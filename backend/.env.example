# ============================================================
# Configuración de la aplicación RAG
# Copia este archivo a ".env" y ajusta los valores necesarios.
# ============================================================

# --- Servidor ---
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:4200

# --- Almacenamiento ---
UPLOAD_DIR=./data/uploads
CHROMA_PERSIST_DIR=./data/chroma_db
COLLECTION_NAME=rag_documents

# --- Chunking ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# --- Embeddings ---
# Modelo local de sentence-transformers (gratuito, no requiere API key)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Retrieval ---
# Nº de fragmentos recuperados por pregunta. Para preguntas puntuales, 4-8 basta;
# para preguntas agregadoras sobre documentos largos ("lista todos los X del libro"),
# conviene subirlo (ver también MAX_CONTEXT_TOKENS, que puede recortar antes de llegar aquí).
TOP_K=6

# --- LLM ---
# Proveedor: "ollama" (local, gratuito) u "openai" (requiere API key)
LLM_PROVIDER=ollama

# Configuración para Ollama (por defecto, 100% local y gratis)
# Instala Ollama desde https://ollama.com y ejecuta: ollama pull llama3.2:3b
# IMPORTANTE: usa el tag exacto que devuelve "ollama list" (p.ej. "llama3.2:3b"),
# no solo "llama3.2" — Ollama no resuelve el nombre sin tag automáticamente.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Configuración para OpenAI (solo si LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Generación ---
LLM_TEMPERATURE=0.1
# Límite del contexto recuperado, en tokens (no caracteres) para dimensionar
# con precisión la ventana del LLM independientemente del idioma/formato.
MAX_CONTEXT_TOKENS=8000
