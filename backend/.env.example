# ============================================================
# Configuración de la aplicación RAG
# Copia este archivo a ".env" y ajusta los valores necesarios.
# ============================================================

# --- Servidor ---
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:4200

# --- Almacenamiento ---
UPLOAD_DIR=./data/uploads
CHROMA_PERSIST_DIR=./data/chroma_db
COLLECTION_NAME=rag_documents

# --- Chunking ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# --- Embeddings ---
# Modelo local de sentence-transformers (gratuito, no requiere API key)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Retrieval ---
TOP_K=4

# --- LLM ---
# Proveedor: "ollama" (local, gratuito) u "openai" (requiere API key)
LLM_PROVIDER=ollama

# Configuración para Ollama (por defecto, 100% local y gratis)
# Instala Ollama desde https://ollama.com y ejecuta: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Configuración para OpenAI (solo si LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Generación ---
LLM_TEMPERATURE=0.1
MAX_CONTEXT_CHARS=6000
